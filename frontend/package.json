{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "generate:api": "openapi-generator-cli generate -i http://localhost:8080/openapi/v1.json -g typescript-angular -o src/app/core/api/generated --additional-properties=ngVersion=22.0.0,providedInRoot=true,withInterfaces=true"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^22.0.0",
