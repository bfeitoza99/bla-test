# Root compose environment — copy to `.env` (git-ignored) and fill in real
# values. These are PLACEHOLDERS; never commit real secrets.
#
# docker-compose.yml reads these. ASP.NET Core uses double-underscore (__) for
# nested config keys; compose composes them into the API's environment.

# --- PostgreSQL (the `db` service) ---
POSTGRES_USER=bla
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bla

# --- API: database connection ---
# The compose `api` service builds ConnectionStrings__Default from the
# POSTGRES_* values above, pointing at Host=db. Nothing to set here separately.

# --- API: JWT bearer settings ---
# SigningKey must be a long, random secret (>= 32 bytes) in real environments.
JWT_ISSUER=bla-api
JWT_AUDIENCE=bla-spa
JWT_SIGNING_KEY=replace-with-a-long-random-secret-at-least-32-bytes

# --- API: CORS ---
# The exact SPA origin allowed to call the API (no AllowAnyOrigin). This is the
# `web` service as seen from the host browser.
CORS_ALLOWED_ORIGIN=http://localhost:4200
