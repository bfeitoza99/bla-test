# Keep the build context small and reproducible. Anything that the multi-stage
# build regenerates (or must never leak) is excluded.

# Build outputs
**/bin/
**/obj/
[Bb]uild/
artifacts/

# Secrets / local env (never bake into an image)
.env
.env.*
!.env.example
*.pfx

# Tests are not needed to publish the API
tests/

# IDE / OS / VCS noise
.vs/
.idea/
*.user
*.swp
.git/
.gitignore
.DS_Store
Thumbs.db
