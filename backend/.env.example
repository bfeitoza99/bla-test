# Backend environment configuration (copy to .env; .env is git-ignored).
# Double-underscore (__) maps to nested config keys in ASP.NET Core.
# These are PLACEHOLDERS — never commit real secrets.

# PostgreSQL connection (points at the docker-compose `db` service by default).
ConnectionStrings__Default=Host=db;Port=5432;Database=bla;Username=bla;Password=change-me

# JWT bearer settings. SigningKey must be a strong, random secret in real environments.
Jwt__Issuer=bla-api
Jwt__Audience=bla-spa
Jwt__SigningKey=replace-with-a-long-random-secret-at-least-32-bytes

# CORS: the exact SPA origin allowed to call the API (no AllowAnyOrigin).
Cors__AllowedOrigin=http://localhost:4200
